# .env.example
# This file is safe to commit.
# Keep keys here, but never put real secrets here.
# Teammates copy this to .env and fill real values.

# App basics
APP_NAME=js-learning-app
APP_ENV=development
APP_PORT=3000

# API settings
# Base URL for backend requests
API_BASE_URL=http://localhost:3000/api
# Request timeout in milliseconds
API_TIMEOUT_MS=10000

# Security secrets
# Use long random values in your real .env
JWT_SECRET=replace_with_long_random_value
SESSION_SECRET=replace_with_long_random_value

# Database
# Format: protocol://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/db_name

# Feature flags (true/false)
FEATURE_LOGIN=true
FEATURE_SIGNUP=true
FEATURE_BETA_DASHBOARD=false

# Logging levels: error, warn, info, debug
LOG_LEVEL=info
